{
  "expo": {
    "name": "OSGARD",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.osgard.mobile",
      "runtimeVersion": {
        "policy": "appVersion"
      },
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "OSGARD распознаёт вашу речь, чтобы заполнить описание артефакта.",
        "NSMicrophoneUsageDescription": "OSGARD использует микрофон для голосового ввода описания артефакта."
      }
    },
    "android": {
      "package": "com.osgard.mobile",
      "runtimeVersion": {
        "policy": "appVersion"
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0A1128"
      },
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0A1128"
        }
      ],
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "OSGARD использует Face ID для быстрого и безопасного входа."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "OSGARD сохраняет созданные артефакты в вашу галерею.",
          "savePhotosPermission": "OSGARD сохраняет созданные артефакты в вашу галерею.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "OSGARD использует микрофон для голосового ввода описания артефакта.",
          "speechRecognitionPermission": "OSGARD распознаёт вашу речь, чтобы заполнить описание артефакта."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/adaptive-icon.png",
          "color": "#00F0FF",
          "sounds": []
        }
      ],
      "@sentry/react-native",
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "updates": {
      "url": "https://u.expo.dev/126712b9-08e9-4b03-a2f4-113363ed066c"
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "126712b9-08e9-4b03-a2f4-113363ed066c"
      }
    },
    "owner": "senjorosas-team"
  }
}
