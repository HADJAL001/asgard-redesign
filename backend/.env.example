# === Сервер ===
PORT=3002
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
# DB_PATH — путь к файлу SQLite (better-sqlite3). На Railway должен указывать на
# смонтированный volume, иначе БД пересоздаётся пустой при каждом деплое.
DB_PATH=./data/osgard.db

# === JWT ===
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=7d

# === Соц-логин (OAuth 2.0 + PKCE) ===
# BACKEND_PUBLIC_URL — публичный адрес ЭТОГО бэкенда, используется для
# построения redirect_uri. Тот же адрес нужно зарегистрировать в консоли
# каждого провайдера как redirect URI: ${BACKEND_PUBLIC_URL}/auth/<provider>/callback
BACKEND_PUBLIC_URL=http://localhost:3002
# FRONTEND_URL — куда бэкенд редиректит после успешного/неуспешного OAuth
FRONTEND_URL=http://localhost:3000

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# === Прочее (уже использующиеся в проекте) ===
ENCRYPTION_KEY=
# REDIS_URL — необязателен. Если не задан, cache.service.ts работает на
# in-memory кеше. Формат — обычная TCP-строка подключения, например Upstash
# "Redis" (не REST) endpoint: redis://default:<password>@<host>:<port>
# или rediss://... для TLS.
REDIS_URL=

# === Stripe (подписки) ===
# STRIPE_SECRET_KEY — sk_test_... в dev/sandbox, sk_live_... в боевом режиме.
# Если не задан — subscription.routes.ts/addons.routes.ts работают в mock-режиме
# (подписка активируется в БД без обращения к Stripe; в NODE_ENV=production запрещено).
STRIPE_SECRET_KEY=
# Webhook endpoint /subscription/webhook — секрет ИМЕННО этого endpoint-а из Stripe Dashboard.
STRIPE_WEBHOOK_SECRET=
# Webhook endpoint /addons/webhook — это ОТДЕЛЬНЫЙ URL в Stripe Dashboard со своим секретом,
# отличным от STRIPE_WEBHOOK_SECRET выше. Если не задан — addons.routes.ts фолбэкается на
# STRIPE_WEBHOOK_SECRET (сработает только если оба webhook-а в Stripe используют один секрет,
# что Stripe не позволяет для двух разных зарегистрированных endpoint-ов).
STRIPE_WEBHOOK_SECRET_ADDONS=
# Price ID тарифов подписки (Stripe Dashboard → Product catalog), см. PlanKey в lib/stripe.ts
STRIPE_PRICE_PRO=
STRIPE_PRICE_SUPREME=
STRIPE_PRICE_DUO=
STRIPE_PRICE_ELITE=
# Price ID addon-подписок ДЖАРВИС/ВАЛЛИ Premium ($99/мес каждая), см. lib/addons.ts
STRIPE_PRICE_JARVIS_PREMIUM=
STRIPE_PRICE_WALLI_PREMIUM=

# === Solana / TimeCoin (казначейство) ===
SOLANA_RPC_URL=
# TREASURY_SECRET_KEY — JSON-массив байт секретного ключа казначейства
TREASURY_SECRET_KEY=
TC_MINT_ADDRESS=

# === AI-провайдеры (цепочка: Claude → DeepSeek → Grok → локальный фолбэк) ===
CLAUDE_API_KEY=
# CLAUDE_API_URL — необязателен, для проксирования запросов к Anthropic через сторонний шлюз
CLAUDE_API_URL=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
GROK_API_KEY=
GROK_MODEL=grok-4-fast

# === Голос ДЖАРВИС/ВАЛЛИ (ElevenLabs TTS, 5 стилей) ===
# Без ключа /jarvis/speak возвращает 503, фронт делает fallback на браузерный TTS
ELEVENLABS_API_KEY=

# === Деплой сгенерированных приложений (Netlify, единый серверный токен) ===
NETLIFY_AUTH_TOKEN=

# === Деплой сгенерированных приложений (Vercel, единый серверный токен) ===
VERCEL_TOKEN=
# VERCEL_TEAM_ID — необязателен, нужен только если токен привязан к команде
VERCEL_TEAM_ID=

# === Публикация сгенерированных приложений в GitHub ===
# Personal Access Token с правом repo — НЕ путать с GITHUB_CLIENT_ID/SECRET
# выше (это OAuth-приложение для соц-логина пользователей)
GITHUB_TOKEN=

# === Обратная связь (feedback.routes.ts) — Telegram и/или Email, оба необязательны ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FEEDBACK_TO_EMAIL=

# === Бэкпрешер очереди записи (write-backpressure.ts) — необязательны, есть дефолты ===
WRITE_QUEUE_MAX_CONCURRENT=20
WRITE_QUEUE_MAX_DEPTH=300
